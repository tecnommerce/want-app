{
  "version": 2,
  "routes": [
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/tienda.html", "dest": "/tienda.html" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/sounds/(.*)", "dest": "/sounds/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/([^/]+?)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/([^/]+)",
      "dest": "/tienda.html?negocio=$1"
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}